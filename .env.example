# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FIREBASE_FUNCTIONS_URL=https://your-function-url.a.run.app

# Application Configuration
NODE_ENV=development # Options: development, production, test
NEXT_PUBLIC_API_URL=http://localhost:3000/api
DATABASE_URL=postgresql://username:password@localhost:5432/dbname
API_KEY=your_api_key_here

# Next.js Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_32_char_string # Use: openssl rand -base64 32

# Instructions:
# 1. Copy this file and rename it to .env.local
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit your actual .env.local file
# 4. Generate NEXTAUTH_SECRET using: openssl rand -base64 32
